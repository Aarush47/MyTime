<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Stopwatch Analog View -->
        <com.example.myclock.StopwatchView
            android:id="@+id/stopwatchView"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginBottom="@dimen/spacing_xlarge" />

        <!-- Time Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_large">

            <TextView
                android:id="@+id/timeDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="76sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="-0.04" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=".00"
                android:textColor="#4d4d4d"
                android:textSize="28sp"
                android:fontFamily="sans-serif-light" />

        </LinearLayout>

        <!-- Control Buttons -->
        <LinearLayout
            android:id="@+id/buttonsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="@dimen/padding_standard"
            android:paddingEnd="@dimen/padding_standard"
            android:layout_marginTop="@dimen/spacing_large">

            <Button
                android:id="@+id/buttonStartStop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_medium"
                android:text="Start"
                android:textColor="#000000"
                android:textSize="@dimen/text_size_button"
                android:textAllCaps="false"
                android:background="@drawable/control_button_primary"
                android:fontFamily="sans-serif"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:padding="@dimen/spacing_medium" />

            <Button
                android:id="@+id/buttonLap"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_medium"
                android:text="Lap"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_button"
                android:textAllCaps="false"
                android:background="@drawable/control_button_secondary"
                android:fontFamily="sans-serif"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:padding="@dimen/spacing_medium" />

        </LinearLayout>

    </LinearLayout>

    <!-- Lap Records - would go here if needed -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/lapTimesRecycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:visibility="gone" />

</FrameLayout>