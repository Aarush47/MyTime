<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_standard"
        android:paddingTop="@dimen/padding_top">

        <!-- Header: Month/Year -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_large">

            <Button
                android:id="@+id/btnPrevMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/prev_symbol"
                android:textColor="#b3b3b3"
                android:textSize="@dimen/text_size_header"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="0dp"
                android:minHeight="0dp"
                style="?attr/borderlessButtonStyle" />

            <TextView
                android:id="@+id/calendarMonthYear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="March 2026"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_main_time"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:letterSpacing="-0.06" />

            <Button
                android:id="@+id/btnNextMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/next_symbol"
                android:textColor="#b3b3b3"
                android:textSize="@dimen/text_size_header"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="0dp"
                android:minHeight="0dp"
                style="?attr/borderlessButtonStyle" />

        </LinearLayout>

        <!-- Week Days Header -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="7"
            android:layout_marginBottom="@dimen/spacing_large">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Sun"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_header"
                android:gravity="center"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Mon"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_header"
                android:gravity="center"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Tue"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_header"
                android:gravity="center"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Wed"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_header"
                android:gravity="center"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Thu"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_header"
                android:gravity="center"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Fri"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_header"
                android:gravity="center"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="Sat"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_header"
                android:gravity="center"
                android:letterSpacing="0.1" />

        </GridLayout>

        <!-- Calendar Grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/calendarGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xlarge"
            android:nestedScrollingEnabled="false" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1a1a1a"
            android:layout_marginBottom="@dimen/spacing_large" />

        <!-- Today's Date Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/spacing_large">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TODAY"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_section_title"
                android:letterSpacing="0.2"
                android:layout_marginBottom="@dimen/spacing_medium" />

            <TextView
                android:id="@+id/calendarDay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="19"
                android:textColor="#FFFFFF"
                android:textSize="72sp"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:letterSpacing="-0.06" />

            <TextView
                android:id="@+id/calendarMonth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="March"
                android:textColor="#b3b3b3"
                android:textSize="@dimen/text_size_main_time"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:layout_marginTop="@dimen/spacing_small"
                android:letterSpacing="-0.06" />

            <TextView
                android:id="@+id/calendarDayName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Wednesday"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_date"
                android:gravity="center"
                android:layout_marginTop="@dimen/spacing_small" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>