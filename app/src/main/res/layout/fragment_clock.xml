<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_standard"
        android:paddingTop="@dimen/padding_top">

        <!-- Header: Day + Format Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_medium">

            <TextView
                android:id="@+id/dayText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="THURSDAY"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_header"
                android:letterSpacing="0.2"
                android:fontFamily="sans-serif" />

            <Button
                android:id="@+id/formatBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12H"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_header"
                android:letterSpacing="0.15"
                android:padding="0dp"
                android:minHeight="0dp"
                style="?attr/borderlessButtonStyle" />

        </LinearLayout>

        <!-- Main Time Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_small"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/timeMainText"
                android:layout_width="297dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="-0.06"
                android:lineHeight="@dimen/line_height_main_time"
                android:text="9:41"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_main_time" />

            <TextView
                android:id="@+id/amPmText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_small"
                android:layout_marginBottom="14dp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.01"
                android:text="AM"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_ampm" />

        </LinearLayout>

        <!-- Full Date -->
        <TextView
            android:id="@+id/dateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="March 19, 2026"
            android:textColor="#4d4d4d"
            android:textSize="@dimen/text_size_date"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_xlarge" />

        <!-- Seconds Progress Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_xlarge">

            <ProgressBar
                android:id="@+id/secondsProgress"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="@dimen/progress_bar_height"
                android:layout_weight="1"
                android:progress="0"
                android:max="59"
                android:progressDrawable="@drawable/progress_bar"
                android:layout_marginEnd="@dimen/spacing_medium" />

            <TextView
                android:id="@+id/secondsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#4d4d4d"
                android:textSize="@dimen/text_size_seconds"
                android:minWidth="20dp"
                android:gravity="right" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1a1a1a"
            android:layout_marginBottom="@dimen/spacing_large" />

        <!-- Ambient Sounds Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AMBIENT"
            android:textColor="#4d4d4d"
            android:textSize="@dimen/text_size_section_title"
            android:letterSpacing="0.2"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_large">

            <FrameLayout
                android:layout_width="@dimen/icon_ambient_size"
                android:layout_height="@dimen/icon_ambient_size"
                android:background="@drawable/ambient_bg">

                <ImageView
                    android:layout_width="@dimen/icon_inner_size"
                    android:layout_height="@dimen/icon_inner_size"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_sound"
                    android:tint="#b3b3b3" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_medium"
                android:layout_marginEnd="@dimen/spacing_medium">

                <TextView
                    android:id="@+id/ambientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ocean Waves"
                    android:textColor="#b3b3b3"
                    android:textSize="@dimen/text_size_ambient_name"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/ambientStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to play"
                    android:textColor="#4d4d4d"
                    android:textSize="@dimen/text_size_ambient_status"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/ambientPlayBtn"
                android:layout_width="@dimen/icon_play_button_size"
                android:layout_height="@dimen/icon_play_button_size"
                android:background="@drawable/play_button_bg"
                android:src="@drawable/ic_play"
                android:scaleType="center"
                android:contentDescription="Play ambient sound" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1a1a1a"
            android:layout_marginBottom="@dimen/spacing_large" />

        <!-- Today's Events -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TODAY"
            android:textColor="#4d4d4d"
            android:textSize="@dimen/text_size_section_title"
            android:letterSpacing="0.2"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Event Items -->
        <LinearLayout
            android:id="@+id/eventsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/spacing_xxlarge" />

    </LinearLayout>

</ScrollView>